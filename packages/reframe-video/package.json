{
  "name": "reframe-video",
  "version": "0.6.47",
  "description": "Declarative motion graphics that AI can write and humans can tweak — human edits survive AI regeneration. Deterministic mp4 renders from a plain-data scene format.",
  "keywords": [
    "motion-graphics",
    "video",
    "animation",
    "generative",
    "ai",
    "deterministic",
    "claude",
    "ffmpeg"
  ],
  "license": "MIT",
  "author": "Kiyeon Jeon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiyeonjeon21/reframe.git"
  },
  "homepage": "https://docs.reframe-video.com",
  "type": "module",
  "bin": {
    "reframe": "./dist/bin.js",
    "reframe-video": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer-canvas.d.ts",
      "import": "./dist/renderer-canvas.js"
    },
    "./compile": {
      "types": "./dist/compile-api.d.ts",
      "import": "./dist/compile-api.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets",
    "guides",
    "preview",
    ".claude-plugin",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "esbuild": "^0.27.0",
    "playwright": "^1.60.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
